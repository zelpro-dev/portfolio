---
import type { ImageMetadata } from 'astro';

type Props = {
  image: ImageMetadata;
}

const { image } = Astro.props;
---

<div class="banner-container">
  <img 
    src={image.src} 
    alt="Banner responsive" 
    width={image.width}
    height={image.height}
    class="banner-image"
    loading="eager"
  />
</div>

<style>
  .banner-container {
    width: 50%;
    aspect-ratio: 1400/1138; 
    overflow: hidden;
    position: relative;
    margin-bottom: 60px;
  }
  
  .banner-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 768px) {
    .banner-container {
      width: 100%;
      aspect-ratio: 1400/1138; 
    }
  }
</style>